<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yeshua Educational Platform – Admin Portal</title>
    <meta name="description" content="Yeshua Educational Platform – Admin management portal." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900;1,14..32,400&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="css/style.css" />
</head>

<body>
    <!-- App Root -->
    <div id="app"></div>

    <!-- Toast Container -->
    <div id="toast-container" aria-live="polite" aria-atomic="false"></div>

    <!-- Scripts -->
    <script src="js/config.js"></script>
    <script src="js/init.js"></script>
    <script src="js/data.js"></script>
    <script src="js/auth.js"></script>
    <script src="js/api.js"></script>
    <script src="js/sync.js"></script>
    <script src="js/router.js"></script>
    <script src="js/ui.js"></script>
    <script src="js/admin.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof DataInit !== 'undefined') {
          DataInit.init();
        }
      });
    </script>
</body>

</html>
